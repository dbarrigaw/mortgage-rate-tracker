# ============ REQUIRED ============

# Anthropic API Key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Turso database (get from https://turso.tech)
TURSO_DATABASE_URL=libsql://your-db-name-your-username.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Gmail credentials
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-char-app-password

# Email recipients (comma-separated)
EMAIL_RECIPIENTS=recipient1@email.com,recipient2@email.com

# ============ OPTIONAL ============

# Server port (Render sets this automatically)
PORT=5000

# Dream For All website URL (update with actual rate page URL)
DREAM_FOR_ALL_URL=https://www.dreamforall.com

# Alert thresholds
ALERT_VOLATILITY_THRESHOLD=0.5
ALERT_THRESHOLD_HIGH=7.5
ALERT_THRESHOLD_LOW=5.5
